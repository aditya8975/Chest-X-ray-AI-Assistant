# Leave unset to use local SQLite (zero setup). Docker Compose sets this
# automatically to point at the Postgres container.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cxr_assistant

# torchxrayvision pretrained weight set
XRV_WEIGHTS=densenet121-res224-all

# A finding is surfaced as "positive" above this model probability
FINDING_THRESHOLD=0.5
# Findings above this (but below FINDING_THRESHOLD) are shown as "borderline"
BORDERLINE_THRESHOLD=0.3

# Set to "true" to force CPU inference even if a GPU is available
FORCE_CPU=false
